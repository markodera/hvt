# Django / Railway
DEBUG=0
SECRET_KEY=change-me-before-production
# Set ALLOWED_HOSTS to your custom backend host(s), or set
# RAILWAY_PUBLIC_DOMAIN to Railway's generated public domain.
ALLOWED_HOSTS=api.hvts.app,healthcheck.railway.app
FRONTEND_URL=https://hvts.app
RAILWAY_PUBLIC_DOMAIN=
CORS_ALLOWED_ORIGINS=https://hvts.app,https://docs.hvts.app
CSRF_TRUSTED_ORIGINS=https://hvts.app,https://api.hvts.app,https://docs.hvts.app
USE_X_FORWARDED_HOST=1
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
JWT_AUTH_SECURE=true
JWT_AUTH_SAMESITE=None
EXPOSE_ADMIN=0
EXPOSE_API_DOCS=0

# Database
DATABASE_URL=
DB_NAME=hvt
DB_USER=hvt
DB_PASSWORD=hvt
DB_HOST=localhost
DB_PORT=5432
# For Railway, set DATABASE_URL from the Postgres service variable reference.
DATABASE_SSL_REQUIRE=0

# Cache
# Local docker-compose uses `redis://redis:6379/0`.
# On Railway, use the Redis service variable reference for REDIS_URL and set USE_REDIS_CACHE=1.
USE_REDIS_CACHE=1
REDIS_URL=redis://localhost:6379/0

# Startup / runtime
WAIT_FOR_DB=1
DB_CONNECT_MAX_ATTEMPTS=45
DB_CONNECT_RETRY_DELAY=2
# Railway runs migrations from railway.json preDeployCommand.
RUN_MIGRATIONS=0
COLLECTSTATIC_ON_START=1
PORT=8000
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# Email
DEFAULT_FROM_EMAIL=noreply@hvts.app
RESEND_API_KEY=
RESEND_WEBHOOK_SIGNING_KEY=

# Social auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional admin bootstrap for Railway deploys
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_FIRST_NAME=
DJANGO_SUPERUSER_LAST_NAME=
