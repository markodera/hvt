# Local development defaults
DEBUG=1
SECRET_KEY=change-me-before-production
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
FRONTEND_URL=http://localhost:5173
RAILWAY_PUBLIC_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000
USE_X_FORWARDED_HOST=0
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
JWT_AUTH_SECURE=false
JWT_AUTH_SAMESITE=Lax
EXPOSE_ADMIN=1
EXPOSE_API_DOCS=1

# Database
DATABASE_URL=
DB_NAME=hvt
DB_USER=hvt
DB_PASSWORD=hvt
DB_HOST=localhost
DB_PORT=5432
# For Railway, set DATABASE_URL from the Postgres service variable reference.
DATABASE_SSL_REQUIRE=0

# Cache
# Enable Redis when running the cache-backed setup.
USE_REDIS_CACHE=0
REDIS_URL=redis://localhost:6379/0

# Startup / runtime
WAIT_FOR_DB=1
DB_CONNECT_MAX_ATTEMPTS=45
DB_CONNECT_RETRY_DELAY=2
# Set RUN_MIGRATIONS=0 on Railway because railway.json handles it.
RUN_MIGRATIONS=1
COLLECTSTATIC_ON_START=0
PORT=8000
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# Email
DEFAULT_FROM_EMAIL=noreply@hvts.app
RESEND_API_KEY=
RESEND_WEBHOOK_SIGNING_KEY=

# Social auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional admin bootstrap for Railway deploys
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_FIRST_NAME=
DJANGO_SUPERUSER_LAST_NAME=

# Production overrides
# DEBUG=0
# ALLOWED_HOSTS=api.example.com,healthcheck.railway.app
# FRONTEND_URL=https://app.example.com
# CORS_ALLOWED_ORIGINS=https://app.example.com
# CSRF_TRUSTED_ORIGINS=https://app.example.com,https://api.example.com
# USE_X_FORWARDED_HOST=1
# SECURE_SSL_REDIRECT=1
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1
# JWT_AUTH_SECURE=true
# JWT_AUTH_SAMESITE=None
# EXPOSE_ADMIN=0
# EXPOSE_API_DOCS=0
# USE_REDIS_CACHE=1
# RUN_MIGRATIONS=0
# COLLECTSTATIC_ON_START=1
